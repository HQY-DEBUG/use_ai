# top 时序约束
# 目标器件：通用 FPGA 开发板示例（Artix-7 / Basys3）
# 生成时间：2026/05/26
# 说明：时序数值须结合实际布局布线报告调整裕量

# ============================================================
# 主时钟定义（100 MHz 单端输入）
# ============================================================
create_clock -period 10.000 -name clk -waveform {0.000 5.000} \
    [get_ports clk]

# ============================================================
# 复位路径（异步复位，豁免时序分析）
# ============================================================
set_false_path -from [get_ports rstn]

# ============================================================
# 输出延迟约束（UART TX 输出）
# ============================================================
# 假设外部接收器建立时间 3.0 ns，保持时间 0.0 ns
set_output_delay -clock clk -max 3.0 [get_ports uart_tx]
set_output_delay -clock clk -min 0.0 [get_ports uart_tx]

# ============================================================
# 输入延迟约束（UART RX 输入）
# ============================================================
set_input_delay -clock clk -max 3.0 [get_ports uart_rx]
set_input_delay -clock clk -min 0.5 [get_ports uart_rx]
